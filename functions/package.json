{
  "name": "star-coaching-functions",
  "private": true,
  "version": "1.0.0",
  "type": "commonjs",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",

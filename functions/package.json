    "firebase-admin": "^12.6.0",
    "firebase-functions": "^6.3.0",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "typescript": "^5.8.3"
  }
}
